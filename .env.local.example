# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

#npm run dev:live
#npm run preview
#npm run build:live

# Azure App Registration (SPA)
VITE_CLIENT_ID=your-app-registration-client-id
VITE_TENANT_ID=your-azure-tenant-id

# SharePoint list (created during manual admin setup)
VITE_SP_SITE_ID=your-sharepoint-site-id        # e.g. contoso.sharepoint.com,abc123,def456
VITE_SP_LIST_ID=your-migration-projects-list-id
